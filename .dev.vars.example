# Copy this to .dev.vars for local development (never commit .dev.vars)
# Leave PROXY_TOKEN empty or unset to disable auth during local testing
PROXY_TOKEN=your-token-here

# ── External provider API keys ──────────────────────────────────────────────
# Set MODEL (and optional MODEL_OPUS/SONNET/HAIKU) to route to a provider:
#   workers_ai                        (default — uses env.AI binding, no key needed)
#   nvidia_nim/meta/llama-3.3-70b-instruct-fp8-fast
#   openrouter/meta-llama/llama-3.3-70b-instruct
#   deepseek/deepseek-chat
#   cloudflare_workers_ai/@cf/meta/llama-3.3-70b-instruct-fp8-fast

# Cloudflare Workers AI (external REST API)
CLOUDFLARE_API_TOKEN=
CLOUDFLARE_ACCOUNT_ID=

# NVIDIA NIM
NVIDIA_NIM_API_KEY=

# OpenRouter
OPENROUTER_API_KEY=

# DeepSeek
DEEPSEEK_API_KEY=
